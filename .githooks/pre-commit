#!/bin/sh
# 커밋 직전에 진행 현황 표(README)를 자동 갱신한다.
# programmers/ 하위 .java 파일 개수를 세어 README를 갱신하고, 변경이 있으면 이번 커밋에 포함한다.

# python 또는 python3 중 사용 가능한 것을 찾는다.
if command -v python >/dev/null 2>&1; then
  PY=python
elif command -v python3 >/dev/null 2>&1; then
  PY=python3
else
  echo "pre-commit: python을 찾을 수 없어 진행 현황 갱신을 건너뜁니다."
  exit 0
fi

"$PY" scripts/update_progress.py || exit 0

# README가 갱신되었으면 이번 커밋에 추가
if ! git diff --quiet -- README.md; then
  git add README.md
fi

exit 0
